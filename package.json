{
  "name": "@regexto/validators",
  "version": "1.0.3",
  "description": "A curated collection of battle-tested regex patterns with TypeScript types, Zod integration, and multi-language code generation.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js"
    }
  },
  "files": [
    "dist",
    "patterns",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "bugs": {
    "url": "https://github.com/regex-to/validators/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/regex-to"
  },
  "scripts": {
    "prebuild": "rm -rf patterns && cp -R ../patterns ./patterns",
    "build": "tsup src/index.ts src/zod.ts --format cjs,esm --dts --clean --shims",
    "dev": "npm run prebuild && tsup src/index.ts --format cjs,esm --dts --watch --shims",
    "pretest": "npm run prebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "regex",
    "validation",
    "typescript",
    "zod",
    "validators",
    "patterns"
  ],
  "author": "regex.to",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/regex-to/validators"
  },
  "homepage": "https://regex.to",
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}